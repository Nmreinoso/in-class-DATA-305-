import { defineConfig } from 'astro/config';

export default defineConfig({
  site: 'https://your-username.github.io',
  base: '/Blog',
});

---
const name = "Natalia";
const education = "College of William & Mary, Economics Major";
const interests = ["Lifting", "Movies", "Music"];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>{name}'s Blog</title>
	</head>
	<body>
		<nav>
			<a href="./">Home</a> | 
			<a href="./resume">Resume</a> | 
			<a href="./posts/hello-world">First Post</a>
		</nav>

		<h1>Hi, I'm {name} 👋</h1>
		<section>
			<h2>Education</h2>
			<p>{education}</p>
		</section>

		<section>
			<h2>Interests</h2>
			<ul>
				{interests.map((item) => <li>{item}</li>)}
			</ul>
		</section>
	</body>
</html>
